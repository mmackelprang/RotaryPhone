@implements IDisposable
@inject ISmsProvider SmsProvider

<div style="padding: 1rem; border: 1px solid #ccc; border-radius: 8px; margin-bottom: 1rem;">
    <h3>SMS / Missed Calls</h3>
    @if (_notifications.Count == 0)
    {
        <p style="color: #888;">No notifications yet</p>
    }
    else
    {
        @foreach (var s in _notifications)
        {
            <div style="margin-bottom: 0.5rem; padding: 0.5rem; background: #f5f5f5; border-radius: 4px;">
                <strong>@(s.Type == SmsType.Sms ? "SMS" : "Missed Call")</strong> from @s.FromNumber
                <span style="color: #888; margin-left: 8px;">@s.ReceivedAt.ToLocalTime().ToString("t")</span>
                @if (s.Body != null)
                {
                    <p style="margin: 0.25rem 0 0;">@s.Body</p>
                }
            </div>
        }
    }
</div>

@code {
    private readonly List<SmsNotification> _notifications = new();

    protected override void OnInitialized()
    {
        SmsProvider.OnSmsReceived += OnNotification;
        SmsProvider.OnMissedCallReceived += OnNotification;
    }

    private void OnNotification(SmsNotification notification)
    {
        _notifications.Add(notification);
        if (_notifications.Count > 20)
            _notifications.RemoveAt(0);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SmsProvider.OnSmsReceived -= OnNotification;
        SmsProvider.OnMissedCallReceived -= OnNotification;
    }
}
